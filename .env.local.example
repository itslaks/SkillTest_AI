# Supabase Configuration
# Get these values from your Supabase dashboard: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

OPENAI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GOOGLE_GEMINI_API_KEY=

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Optional: Site URL for authentication redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional local seed script credentials
SEED_ADMIN_PASSWORD=
SEED_TRAINER_PASSWORD=
ALLOW_DEMO_SEED_CREDENTIALS=0
