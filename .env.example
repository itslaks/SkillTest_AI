# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI Configuration (Optional)
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=replace_with_a_long_random_secret

# Email - Resend (https://resend.com)
# Required for: attendance cutoff alerts, absence streak alerts, assessment reminders,
# feedback request emails, upload confirmation emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Maverick TMS <noreply@yourdomain.com>

# Development
NODE_ENV=development

# Optional local seed script credentials
SEED_ADMIN_PASSWORD=
SEED_TRAINER_PASSWORD=
# Set to 1 only for throwaway local demos if you want the seed script defaults.
ALLOW_DEMO_SEED_CREDENTIALS=0
