# ─── Supabase (Required) ────────────────────────────────────────────────
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only: Service Role Key (NEVER expose to client)
# Required for admin operations like bulk imports
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Site Configuration ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Override redirect URL for local development (optional)
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/auth/callback

# ─── AI / Question Generation (Optional) ────────────────────────────────
# If using OpenAI for dynamic MCQ generation:
# OPENAI_API_KEY=sk-...
# If using Google Gemini:
# GOOGLE_GEMINI_API_KEY=...

# ─── IMPORTANT ──────────────────────────────────────────────────────────
# 1. Copy this file as .env.local and fill in real values.
# 2. NEVER commit .env.local to version control.
# 3. Rotate keys immediately if they are ever exposed.
# 4. Only NEXT_PUBLIC_* vars are visible to the browser.
